# DashScope API
DASHSCOPE_API_KEY=

# LLM 配置
LLM_MODEL=qwen3-max
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT=120
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# Embedding 配置
EMBEDDING_MODEL=bge-large-zh-v1.5
EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
EMBEDDING_API_KEY=placeholder
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=10
EMBEDDING_MAX_INPUT_LENGTH=800
EMBEDDING_QUERY_PREFIX=为这个句子生成表示以用于检索相关文章：

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=rag_system

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 认证
AUTH_ENABLED=true

# 查询改写配置
QUERY_REWRITE_ENABLED=false
QUERY_REWRITE_COUNT=3

# Reranker 配置（留空则不启用）
RERANK_API_URL=http://127.0.0.1:8001/v1/rerank
RERANK_API_KEY=
RERANK_MODEL=bge-reranker-large
RERANK_FETCH_MULTIPLIER=1

# 数据源密码加密密钥（Fernet key，必须配置）
ENCRYPTION_KEY=

# 元数据同步间隔（小时）
METADATA_SYNC_INTERVAL_HOURS=24

# 元数据学习配置
LEARNING_L2_MAX_CONCURRENCY=5
LEARNING_JOB_TIMEOUT_MINUTES=60
