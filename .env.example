# 数据库连接（目标查询库 - 只读）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=readonly
DB_PASSWORD=

# 元数据库（PostgreSQL）
META_DB_URL=postgresql+asyncpg://chatdb:chatdb@localhost:5433/chatdb_meta

# LLM 配置
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 向量库（Milvus）
MILVUS_HOST=localhost
MILVUS_PORT=19530

# 图数据库（Neo4j）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Redis
REDIS_URL=redis://localhost:6379/0
